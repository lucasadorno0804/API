{
  "name": "bsl-root",
  "version": "1.0.0",
  "description": "Workspace Root for BSL Application",
  "scripts": {
    "dev:web": "npm run dev --prefix bsl-web",
    "dev:api": "npm run dev --prefix bsl-api",
    "dev:all": "npx concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "install:all": "npm install --prefix bsl-web && npm install --prefix bsl-api",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "start": "node bsl-api/index.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC"
}